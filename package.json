{
  "name": "restaurant-digital-menu",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "node scripts/postinstall.mjs",
    "seed": "node scripts/seed.mjs",
    "seed:force": "node scripts/seed.mjs --force",
    "seed:production": "node scripts/seed.mjs --production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "vitest run && playwright test",
    "test:security": "vitest run tests/security",
    "test:security-gate": "tsx tests/security-gate/rls-verify.ts && tsx tests/security-gate/rbac-matrix.ts && tsx tests/security-gate/webhook-security.ts && tsx tests/security-gate/jwt-forgery.ts && tsx tests/security-gate/cross-tenant-probe.ts",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "pretest": "node -e \"if (!process.env.CI) { require('fs').readFileSync('tests/.env.test','utf-8').split('\\n').filter(Boolean).forEach(l=>{var m=l.match(/^([^=]+)=(.+)/);if(m)process.env[m[1]]=m[2].trim()}) }\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-compose-refs": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "libsodium-wrappers": "0.8.4",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "hermes-parser": "0.36.1",
    "supertest": "7.2.2",
    "tailwindcss": "^4",
    "tinyglobby": "0.2.12",
    "tsconfig-paths": "4.2.0",
    "typescript": "^5",
    "vitest": "4.1.9"
  },
  "overrides": {
    "@radix-ui/react-compose-refs": "$@radix-ui/react-compose-refs",
    "@swc/helpers": "^0.5.15"
  }
}
