# =============================================================================
# Restaurant Digital Menu — Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in real values.
#   cp .env.production.example .env.production
#
# Variables prefixed with NEXT_PUBLIC_ are bundled into the browser client
# and visible to anyone. NEVER put secrets in NEXT_PUBLIC_ variables.
# Variables WITHOUT the prefix are server-only and must be kept secure.
# =============================================================================

# ─── Supabase (Public — visible to browser) ─────────────────────────────────
# Your Supabase project URL (e.g. https://xyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous/public key (safe for client-side use; Row Level Security
# is what protects your data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Supabase (Server-only — SECRET) ─────────────────────────────────────────
# Service role key bypasses RLS. Use ONLY in trusted server contexts
# (API routes, webhooks, scheduled jobs). Never expose to the client.
# SECRET: Guard this value like a password.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Chapa Payment Gateway (Server-only) ─────────────────────────────────────
# Secret key for server-to-server Chapa API authentication.
# SECRET: Keep this value secure.
CHAPA_SECRET_KEY=

# Chapa API base URL. Use https://api.chapa.co/v1 for production.
CHAPA_API_URL=https://api.chapa.co/v1

# ─── Application URLs (Public) ───────────────────────────────────────────────
# Full canonical URL of the production application (no trailing slash).
NEXT_PUBLIC_APP_URL=

# Human-readable application name displayed in the UI and page titles.
NEXT_PUBLIC_APP_NAME=Restaurant Digital Menu

# ─── Encryption (Server-only — SECRET) ───────────────────────────────────────
# Symmetric encryption key used for encrypting sensitive fields at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SECRET: Store in your vault / secrets manager.
ENCRYPTION_KEY=

# ─── Sentry Error Tracking (Optional) ────────────────────────────────────────
# Server-side Sentry DSN for backend / API route error reporting.
# Leave blank if not using Sentry.
SENTRY_DSN=

# Client-side Sentry DSN (public — visible to browser).
# Leave blank if not using Sentry.
NEXT_PUBLIC_SENTRY_DSN=

# ─── Logging (Server-only) ───────────────────────────────────────────────────
# Controls log verbosity. One of: silent, error, warn, info, debug.
# Recommended: info for production, debug for staging.
LOG_LEVEL=info

# ─── Rate Limiting (Server-only) ─────────────────────────────────────────────
# Maximum number of requests allowed within the rate-limit window per IP.
RATE_LIMIT_MAX=100

# Rate-limit window duration in milliseconds (e.g. 60000 = 1 minute).
RATE_LIMIT_WINDOW_MS=60000
